# Local Ollama config — no API key needed
# Run: ollama serve  (starts on port 11434 by default)
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# Other models with good tool-use support:
#   OLLAMA_MODEL=qwen2.5          (excellent tool use, slightly smaller)
#   OLLAMA_MODEL=mistral-nemo     (fast, good tool use)
#   OLLAMA_MODEL=llama3.2         (3B — fastest, lighter tool use)

# Datadog (optional)
DD_API_KEY=
DD_ENV=development
DD_SERVICE=datalens
DD_VERSION=1.0.0
DD_TRACE_ENABLED=false

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
