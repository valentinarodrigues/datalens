# ── LLM Backend ────────────────────────────────────────────────────────────────
# Controls which LLM the agent uses. Switch without touching any other code.
#
#   bedrock  (default) — Amazon Bedrock. Requires AWS credentials + model enabled.
#   ollama             — Local Ollama server. No AWS account needed. Great for local dev.
LLM_BACKEND=bedrock

# ── Amazon Bedrock (used when LLM_BACKEND=bedrock) ────────────────────────────
# Auth: standard boto3 credential chain — no hardcoded keys.
#   Local dev: set AWS_PROFILE (recommended) or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
#   Lambda:    execution role IAM permissions (configured via template.yaml)
#
# The model must be enabled in your account first:
#   Bedrock console → Model access → Enable chosen model
#
# Supported model IDs:
#   anthropic.claude-3-5-sonnet-20241022-v2:0   ← default, best tool use
#   anthropic.claude-3-haiku-20240307-v1:0       ← faster, cheaper
#   anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_REGION=us-east-1

# AWS profile for local dev (comment out to use default profile or instance role)
# AWS_PROFILE=my-dev-profile

# ── Ollama (used when LLM_BACKEND=ollama) ─────────────────────────────────────
# Requires Ollama running locally: https://ollama.com
#   brew install ollama
#   ollama serve                          # keep running in a dedicated terminal
#   ollama pull llama3.1                  # 4.9 GB — best reasoning + tool use
#   ollama pull llama3.2                  # 2.0 GB — faster on CPU, lighter tool use
#
# Other models with good tool-use support:
#   OLLAMA_MODEL=qwen2.5                  # excellent tool use, slightly smaller
#   OLLAMA_MODEL=mistral-nemo             # fast, good tool use
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# ── DynamoDB — Usage Statistics ────────────────────────────────────────────────
# Leave blank to fall back to mock data (no AWS needed for pure local dev).
# After `sam deploy`, set this to the UsageTableName stack output value, e.g.:
#   aws cloudformation describe-stacks \
#       --stack-name datalens \
#       --query "Stacks[0].Outputs[?OutputKey=='UsageTableName'].OutputValue" \
#       --output text
USAGE_TABLE_NAME=

# ── Datadog (optional) ─────────────────────────────────────────────────────────
DD_API_KEY=
DD_ENV=development
DD_SERVICE=datalens
DD_VERSION=1.0.0
DD_TRACE_ENABLED=false

# ── CORS — comma-separated origins ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── External tools (optional) ──────────────────────────────────────────────────
# All are read-only PATs. Omit/blank to disable that tool gracefully.

# Confluence
# CONFLUENCE_URL=https://yourco.atlassian.net/wiki
# CONFLUENCE_API_TOKEN=your_pat

# JIRA
# JIRA_URL=https://yourco.atlassian.net
# JIRA_EMAIL=your@email.com
# JIRA_API_TOKEN=your_pat

# GitHub
# GITHUB_TOKEN=ghp_your_pat
# GITHUB_ORG=your-org
